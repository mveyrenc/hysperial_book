<%= app_form_with model: object do |form| %>
  <%= form.inputs do %>
    <%= form.input :title, required: true %>
    <%= form.input :book, as: :select, collection: Book.sorted %>
    <%= form.input :book, as: :radio, collection: Book.sorted %>
    <%= form.input :book, as: :check_boxes, collection: Book.sorted %>
    <%= form.input :book, as: :datalist, collection: Book.sorted %>
    <%= form.input :short_description, as: :rich_text_area %>
    <%= form.input :body, as: :rich_text_area %>
    <%= form.input :thumbnail %>
    <%= image_tag object.thumbnail if object.persisted? and object.thumbnail.attached? %>
  <% end %>
  <%= form.actions do %>
    <%= form.button :submit %>
  <% end %>
<% end %>
